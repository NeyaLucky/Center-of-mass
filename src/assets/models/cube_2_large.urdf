<?xml version="1.0" ?>
<robot name="cube_2_large">
    <link name="cube_link_2_large">
        <inertial>
            <!-- CoM shifted -30 mm along Z — same 37% half-side ratio as cube_2
                 (-17.12 mm / 46 mm half-side = 37%  →  37% * 80 mm = 29.6 mm ≈ 30 mm) -->
            <origin rpy="0 0 0" xyz="0.0 0.0 -0.030"/>

            <mass value="2.5"/>

            <!-- Solid cube: I = m*s^2/6  s=0.16 m, m=2.5 kg -->
            <!-- I = 2.5 * 0.16^2 / 6 = 0.010667 kg*m^2  (at CoM) -->
            <inertia
                ixx="0.010667"
                ixy="0.0"
                ixz="0.0"
                iyy="0.010667"
                iyz="0.0"
                izz="0.010667"/>
        </inertial>

        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <box size="0.16 0.16 0.16"/>
            </geometry>
            <material name="Orange">
                <color rgba="0.9 0.5 0.1 1.0"/>
            </material>
        </visual>

        <collision>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <box size="0.16 0.16 0.16"/>
            </geometry>
        </collision>
    </link>
</robot>
